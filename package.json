{
  "name": "ycms",
  "private": true,
  "scripts": {
    "dev": "(cd packages/app && bun dev)",
    "build": "(cd packages/app && bun run build)",
    "preview": "(cd packages/app && bun run preview)",
    "lint": "biome check packages/",
    "lint:fix": "biome check --write packages/",
    "format": "biome format --write packages/",
    "clean": "bash clean.sh"
  },
  "workspaces": [
    "packages/**"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.16"
  }
}
