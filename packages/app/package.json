{
	"name": "@ycms/app",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun run dev:all",
		"dev:client": "vite",
		"dev:server": "bun run api/server.ts",
		"dev:all": "concurrently \"bun --watch api/server.ts\" \"vite\"",
